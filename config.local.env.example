# Sao chép thành config.local.env — đường dẫn tương đối repo (tùy chọn).

# SDK / log ngoài repo (chỉ khi không dùng vendor/sdk sau bootstrap)
# DAHUA_SDK_DIR=vendor/sdk
# SMARTPSS_LOG_DIR=.cache/smartpss-log

# Thiết bị
# DAHUA_PASS=
# DAHUA_SERIAL=
# DAHUA_LAN_IP=

# CLI-only playback_clip.py
# DAHUA_CONNECT_MODE=auto     # auto|p2p|direct
# DAHUA_P2P_SERVER=easy4ip    # easy4ip|dolynk
# DAHUA_P2P_TYPE=0
# DAHUA_P2P_RELAY=1
# DAHUA_P2P_LISTEN_PORT=8554
# DAHUA_RECORD_MINUTES_AGO=1
# DAHUA_RECORD_DURATION_SEC=60
# DAHUA_RECORD_TIMEOUT_SEC=180
# DAHUA_RECORD_RETRIES=4
